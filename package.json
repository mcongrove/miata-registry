{
	"name": "miata-registry",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"homepage": "https://miataregistry.com",
	"bugs": {
		"url": "https://github.com/mcongrove/miata-registry/issues",
		"email": "support@miataregistry.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/mcongrove/miata-registry.git"
	},
	"scripts": {
		"build": "tsc && vite build",
		"db:backup": "wrangler d1 export registry --remote --output=backups/registry-$(date +%s).sqlite",
		"db:generate": "drizzle-kit generate",
		"db:push": "drizzle-kit push",
		"dev": "vite",
		"email:dev": "email dev --dir src/emails",
		"format": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\"",
		"lint": "eslint .",
		"preview": "vite preview",
		"worker:build": "esbuild src/worker/index.ts --bundle --outfile=dist/worker.js --format=esm --platform=browser",
		"worker:deploy:prod": "wrangler deploy --keep-vars",
		"worker:deploy": "npm run worker:build && npx wrangler deploy --keep-vars",
		"worker:dev": "wrangler dev src/worker/index.ts --remote --env development"
	},
	"dependencies": {
		"@clerk/backend": "^3.10.0",
		"@clerk/clerk-react": "^5.61.8",
		"@cloudflare/workers-types": "^4.20260617.1",
		"@floating-ui/react": "^0.27.19",
		"@react-email/render": "^2.0.10",
		"@react-google-maps/api": "^2.20.8",
		"browser-image-compression": "^2.0.2",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.12.25",
		"jszip": "^3.10.1",
		"qrcode.react": "^4.2.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-hot-toast": "^2.6.0",
		"react-markdown": "^10.1.0",
		"react-router-dom": "^7.18.0",
		"react-email": "^6.6.6",
		"resend": "^6.17.1"
	},
	"devDependencies": {
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.1.8",
		"@react-email/ui": "^6.6.6",
		"@types/node": "^22.19.21",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^4.7.0",
		"autoprefixer": "^10.5.0",
		"csv-parse": "^5.6.0",
		"dotenv": "^16.6.1",
		"drizzle-kit": "^0.31.10",
		"esbuild": "^0.28.1",
		"eslint": "^9.39.4",
		"eslint-plugin-react-hooks": "^5.2.0",
		"eslint-plugin-react-refresh": "^0.4.20",
		"globals": "^16.0.0",
		"postcss": "^8.5.15",
		"prettier": "^3.8.4",
		"tailwind-merge": "^3.3.0",
		"tailwindcss": "^4.1.8",
		"terser": "^5.48.0",
		"ts-node": "^10.9.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.32.0",
		"vite": "^6.3.5",
		"vite-plugin-svgr": "^4.5.0",
		"wrangler": "^4.107.0"
	}
}
