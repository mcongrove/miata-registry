{
	"name": "miata-registry",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"build": "tsc && vite build",
		"db:backup": "wrangler d1 export registry --remote --output=backups/registry-$(date +%s).sqlite",
		"db:generate": "drizzle-kit generate:sqlite",
		"db:push": "drizzle-kit push:sqlite",
		"dev": "vite",
		"email:dev": "email dev --dir src/emails",
		"format": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\"",
		"lint": "eslint .",
		"preview": "vite preview",
		"worker:build": "esbuild src/worker/index.ts --bundle --outfile=dist/worker.js --format=esm --platform=browser",
		"worker:deploy:prod": "wrangler deploy --keep-vars",
		"worker:deploy": "npm run worker:build && npx wrangler deploy --keep-vars",
		"worker:dev": "wrangler dev src/worker/index.ts --remote --env development"
	},
	"dependencies": {
		"@clerk/backend": "^1.21.4",
		"@clerk/clerk-react": "^5.61.8",
		"@cloudflare/workers-types": "^4.20241224.0",
		"@floating-ui/react": "^0.27.19",
		"@react-email/components": "0.0.31",
		"@react-google-maps/api": "^2.20.8",
		"browser-image-compression": "^2.0.2",
		"drizzle-orm": "^0.38.3",
		"hono": "^4.6.14",
		"jszip": "^3.10.1",
		"qrcode.react": "^4.2.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-hot-toast": "^2.6.0",
		"react-markdown": "^10.1.0",
		"react-router-dom": "^7.18.0",
		"resend": "^4.0.1"
	},
	"devDependencies": {
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.1.8",
		"@types/node": "^22.10.2",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^4.7.0",
		"autoprefixer": "^10.4.20",
		"csv-parse": "^5.6.0",
		"dotenv": "^16.4.7",
		"drizzle-kit": "^0.30.1",
		"esbuild": "^0.20.0",
		"eslint": "^9.9.0",
		"eslint-plugin-react-hooks": "^5.2.0",
		"eslint-plugin-react-refresh": "^0.4.20",
		"globals": "^16.0.0",
		"postcss": "^8.4.45",
		"prettier": "^3.3.3",
		"react-email": "^3.0.4",
		"tailwind-merge": "^3.3.0",
		"tailwindcss": "^4.1.8",
		"terser": "^5.37.0",
		"ts-node": "^10.9.2",
		"typescript": "^5.7.2",
		"typescript-eslint": "^8.32.0",
		"vite": "^6.3.5",
		"vite-plugin-svgr": "^4.5.0",
		"wrangler": "^3.99.0"
	}
}
